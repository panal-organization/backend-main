MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>
PORT=3000
AI_SERVICE_URL=http://127.0.0.1:8000
AI_INTERNAL_API_KEY=change_me_internal_api_key

# IA Agent Configuration
# AI_DEMO_MODE=true → permite crear tickets SIN JWT (requiere AI_DEMO_USER_ID y AI_DEMO_WORKSPACE_ID)
# AI_DEMO_MODE=false (o no configurado) → requiere JWT + suscripción activa del usuario
AI_DEMO_MODE=false
AI_DEMO_USER_ID=<mongo_object_id>
AI_DEMO_WORKSPACE_ID=<mongo_object_id>

# Email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SECURE=false
ADMIN_NOTIFICATION_EMAIL=admin@example.com
